// Configuração principal do Prisma, define o banco de dados e as tabelas (Models)
// Para aplicar alterações, execute: npx prisma migrate dev
generator client {
  provider = "prisma-client-js"
}

// Configuração do driver do banco de dados (neste caso, PostgreSQL)
datasource db {
  provider = "postgresql"
}

// Modelo "Pessoa" que representa a tabela de pessoas no banco de dados
model Pessoa {
  id            String         @id @default(uuid())
  nome          String
  email         String         @unique
  telefone      String
  descricao     String? // A interrogação indica que é opcional (Breve descrição)
  senha         String // Hash bcrypt da senha para autenticação
  isAdmin       Boolean        @default(false) @map("is_admin")
  conhecimentos Conhecimento[] // Relação 1:N
  criadoEm      DateTime       @default(now())

  @@map("pessoas")
}

// Enum para o nível de conhecimento
enum Nivel {
  BASICO        @map("basico")
  INTERMEDIARIO @map("intermediario")
  AVANCADO      @map("avancado")

  @@map("niveis")
}

enum Categoria {
  MUSICA     @map("musica")
  TECNOLOGIA @map("tecnologia")
  EDUCACAO   @map("educacao")
  ARTES      @map("artes")
  IDIOMAS    @map("idiomas")
  OUTROS     @map("outros")

  @@map("categorias")
}

// Modelo "Conhecimento" que representa a tabela de conhecimentos no banco de dados
model Conhecimento {
  id        String    @id @default(uuid())
  titulo    String
  descricao String
  categoria Categoria
  nivel     Nivel
  pessoaId  String    @map("pessoa_id")
  pessoa    Pessoa    @relation(fields: [pessoaId], references: [id], onDelete: Cascade)
  criadoEm  DateTime  @default(now())

  @@map("conhecimentos")
}
